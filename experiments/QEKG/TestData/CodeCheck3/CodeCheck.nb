Cell[BoxData[{
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"ToFileName", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"\"\<FileName\>\"", "/.", 
        RowBox[{"NotebookInformation", "[", 
         RowBox[{"EvaluationNotebook", "[", "]"}], "]"}]}], ")"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<Data\>\""}], "]"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Clear", "[", 
   RowBox[{"AllFiles", ",", "FileData1", ",", "len1", ",", "f"}], "]"}], ";", 
  
  RowBox[{"AllFiles", "=", 
   RowBox[{"Sort", "[", 
    RowBox[{"FileNames", "[", "\"\<*.csv\>\"", "]"}], "]"}]}], ";", 
  RowBox[{"len1", "=", 
   RowBox[{"Length", "[", "AllFiles", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"i", "=", "1"}], ",", 
    RowBox[{"i", "\[LessEqual]", "len1"}], ",", 
    RowBox[{"i", "++"}], ",", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"f", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"AllFiles", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ";", 
       RowBox[{
        RowBox[{"FileData1", "[", "i", "]"}], "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Take", "[", 
          RowBox[{"f", ",", 
           RowBox[{"{", 
            RowBox[{"1", ",", 
             RowBox[{"-", "1"}]}], "}"}]}], "]"}], "]"}]}]}], ",", 
      RowBox[{"Clear", "[", "f", "]"}]}], "}"}]}], "]"}], ";"}]}], "Input",
